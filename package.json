{
  "name": "bookit",
  "productName": "Bookit",
  "version": "2.0.0",
  "type": "module",
  "description": "Bookit - Modern booking management desktop application built with Electron and React.",
  "author": "Iqbal Ussain",
  "private": true,
  "main": "main.cjs",
  "homepage": "./",
  "scripts": {
    "dev": "cross-env NODE_ENV=development vite",
    "build": "vite build",
    "electron": "electron .",
    "electron-dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "start": "electron .",
    "rebuild-electron": "electron-rebuild",
    "dist": "npm run build && npx electron-builder --win nsis --x64 --publish never",
    "build-win": "npm run build && npm run rebuild-electron && npx electron-builder --win nsis --x64 --publish never"
  },
